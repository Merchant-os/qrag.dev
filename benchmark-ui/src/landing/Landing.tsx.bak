import React, { useEffect, useRef, useState } from "react";
import { Link } from "react-router-dom";
import { SiteNav } from "../components/SiteNav";

interface LandingProps {
  dashboardUrl?: string;
}

export function Landing({ dashboardUrl = "/dashboard" }: LandingProps) {
  const [isScrolling, setIsScrolling] = useState(false);
  const [menuTheme, setMenuTheme] = useState<"light" | "dark">("light");
  const scrollTimeout = useRef<number | null>(null);

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolling(true);
      if (scrollTimeout.current) {
        window.clearTimeout(scrollTimeout.current);
      }
      scrollTimeout.current = window.setTimeout(() => {
        setIsScrolling(false);
      }, 180);
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    return () => {
      window.removeEventListener("scroll", handleScroll);
      if (scrollTimeout.current) {
        window.clearTimeout(scrollTimeout.current);
      }
    };
  }, []);

  useEffect(() => {
    const elements = Array.from(document.querySelectorAll(".scroll-reveal"));
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const target = entry.target as HTMLElement;
          const group = target.dataset.revealGroup;
          if (group) {
            document
              .querySelectorAll(`[data-reveal-group="${group}"]`)
              .forEach((element) => element.classList.add("is-visible"));
          } else {
            target.classList.add("is-visible");
          }
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.18 }
    );

    elements.forEach((element) => observer.observe(element));
    return () => observer.disconnect();
  }, []);

  useEffect(() => {
    const sections = Array.from(document.querySelectorAll("[data-nav-theme]"));
    if (!sections.length) return;

    const intersecting = new Set<Element>();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            intersecting.add(entry.target);
          } else {
            intersecting.delete(entry.target);
          }
        });

        const hasDark = Array.from(intersecting).some(
          (element) => element.getAttribute("data-nav-theme") === "dark"
        );
        setMenuTheme(hasDark ? "dark" : "light");
      },
      { threshold: 0.25 }
    );

    sections.forEach((section) => observer.observe(section));
    return () => observer.disconnect();
  }, []);

  return (
    <div className="bg-[#fbf7f2] text-[#0b0f19]">
      <SiteNav isHidden={isScrolling} theme={menuTheme} />

      <main className="flex w-full flex-col pt-[120px] scroll-smooth">
        <section
          className="scroll-reveal is-visible stack-section relative mx-auto flex min-h-[calc(100vh-120px)] w-full max-w-[1440px] items-center px-6 py-8 lg:px-12"
          style={{ zIndex: 5 }}
        >
          <div className="grid grid-cols-1 items-center gap-16 lg:grid-cols-12">
            <div className="flex flex-col gap-10 pr-0 lg:col-span-7 lg:pr-12">
              <div className="flex flex-col gap-8">
                <span className="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-[#9ca3af]">
                  QRAG - Quantum Retrieval Augmented Generation
                </span>
                <h1 className="font-display text-6xl font-normal leading-[0.9] tracking-tight text-black lg:text-[96px]">
                  Smarter Q#
                  <br />
                  code.
                </h1>
              </div>
              <p className="max-w-[520px] text-lg font-light leading-[1.5] text-[#6b7280]">
                Retrieval-augmented Q# generation with verified docs and test-ready output.
              </p>
              <div className="flex flex-wrap gap-5 pt-2">
                <Link
                  className="inline-flex h-12 items-center justify-center rounded-[4px] bg-[#c9a66b] px-8 text-sm font-semibold tracking-wide text-white shadow-sm transition-all duration-300 hover:bg-[#b8955c] hover:shadow-lg"
                  to={dashboardUrl}
                >
                  View Results
                </Link>
                <Link
                  className="inline-flex h-12 items-center justify-center text-sm font-medium text-[#374151] transition-colors hover:text-black"
                  to="/results"
                >
                  Read Docs
                  <span className="material-symbols-outlined ml-2 text-[16px]" aria-hidden="true">arrow_outward</span>
                </Link>
              </div>
            </div>

            <div className="relative mt-12 lg:col-span-5 lg:mt-0">
              <div className="relative origin-top-right scale-100 overflow-hidden rounded-lg border border-gray-100 bg-[#fafafa] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_70px_rgba(15,23,42,0.25)] lg:scale-105">
                <div className="flex items-center justify-between border-b border-gray-100 bg-white px-5 py-4">
                  <div className="flex gap-2">
                    <div className="h-2 w-2 rounded-full bg-gray-200" />
                    <div className="h-2 w-2 rounded-full bg-gray-200" />
                    <div className="h-2 w-2 rounded-full bg-gray-200" />
                  </div>
                  <div className="font-mono text-[10px] tracking-wide text-gray-400">Main.qs</div>
                </div>
                <div className="bg-white p-8">
                  <pre className="font-mono text-xs leading-relaxed text-gray-800">
                    <code>
                      <span className="text-[#2d4b7a]">namespace</span>{" "}
                      <span className="text-[#0f766e]">Quantum.RAG</span>{" "}
                      <span className="text-gray-500">{"{"}</span>
                      {"\n    "}
                      <span className="text-[#2d4b7a]">open</span>{" "}
                      <span className="text-[#0f766e]">Microsoft.Quantum.Intrinsic</span>
                      <span className="text-gray-500">;</span>
                      {"\n    "}
                      <span className="text-[#2d4b7a]">open</span>{" "}
                      <span className="text-[#0f766e]">Microsoft.Quantum.Canon</span>
                      <span className="text-gray-500">;</span>
                      {"\n    "}
                      <span className="text-[#9ca3af]">// Generated by QRAG Agent</span>
                      {"\n    "}
                      <span className="text-[#2d4b7a]">operation</span>{" "}
                      <span className="text-[#c2410c]">Teleport</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">msg</span>
                      <span className="text-gray-500"> : </span>
                      <span className="text-[#a855f7]">Qubit</span>
                      <span className="text-gray-500">, </span>
                      <span className="text-[#0f766e]">target</span>
                      <span className="text-gray-500"> : </span>
                      <span className="text-[#a855f7]">Qubit</span>
                      <span className="text-gray-500">) : </span>
                      <span className="text-[#a855f7]">Unit</span>
                      <span className="text-gray-500"> {"{"}</span>
                      {"\n        "}
                      <span className="text-[#2d4b7a]">use</span>{" "}
                      <span className="text-[#0f766e]">register</span>
                      <span className="text-gray-500"> = </span>
                      <span className="text-[#a855f7]">Qubit</span>
                      <span className="text-gray-500">[</span>1<span className="text-gray-500">];</span>
                      {"\n        "}
                      <span className="text-[#c2410c]">H</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">register</span>
                      <span className="text-gray-500">[</span>0<span className="text-gray-500">]);</span>
                      {"\n        "}
                      <span className="text-[#c2410c]">CNOT</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">register</span>
                      <span className="text-gray-500">[</span>0<span className="text-gray-500">], </span>
                      <span className="text-[#0f766e]">target</span>
                      <span className="text-gray-500">);</span>
                      {"\n        "}
                      <span className="text-[#c2410c]">CNOT</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">msg</span>
                      <span className="text-gray-500">, </span>
                      <span className="text-[#0f766e]">register</span>
                      <span className="text-gray-500">[</span>0<span className="text-gray-500">]);</span>
                      {"\n        "}
                      <span className="text-[#c2410c]">H</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">msg</span>
                      <span className="text-gray-500">);</span>
                      {"\n        "}
                      <span className="text-[#2d4b7a]">let</span>{" "}
                      <span className="text-[#0f766e]">data1</span>
                      <span className="text-gray-500"> = </span>
                      <span className="text-[#c2410c]">M</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">msg</span>
                      <span className="text-gray-500">);</span>
                      {"\n        "}
                      <span className="text-[#2d4b7a]">if</span>
                      <span className="text-gray-500"> (</span>
                      <span className="text-[#0f766e]">data1</span>
                      <span className="text-gray-500"> == </span>
                      <span className="text-[#a855f7]">One</span>
                      <span className="text-gray-500">) {"{"} </span>
                      <span className="text-[#c2410c]">Z</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">target</span>
                      <span className="text-gray-500">); {"}"}</span>
                      {"\n        "}
                      <span className="text-[#2d4b7a]">let</span>{" "}
                      <span className="text-[#0f766e]">data2</span>
                      <span className="text-gray-500"> = </span>
                      <span className="text-[#c2410c]">M</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">register</span>
                      <span className="text-gray-500">[</span>0<span className="text-gray-500">]);</span>
                      {"\n        "}
                      <span className="text-[#2d4b7a]">if</span>
                      <span className="text-gray-500"> (</span>
                      <span className="text-[#0f766e]">data2</span>
                      <span className="text-gray-500"> == </span>
                      <span className="text-[#a855f7]">One</span>
                      <span className="text-gray-500">) {"{"} </span>
                      <span className="text-[#c2410c]">X</span>
                      <span className="text-gray-500">(</span>
                      <span className="text-[#0f766e]">target</span>
                      <span className="text-gray-500">); {"}"}</span>
                      {"\n    "}
                      <span className="text-gray-500">{"}"}</span>
                      {"\n"}
                      <span className="text-gray-500">{"}"}</span>
                    </code>
                  </pre>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section
          className="scroll-reveal stack-section relative flex min-h-[calc(100vh-120px)] w-full items-center bg-white py-16"
          id="how-it-works"
          style={{ transitionDelay: "0ms", zIndex: 1 }}
        >
          <div
            className="pointer-events-none absolute inset-0 opacity-100"
            style={{
              backgroundImage:
                "linear-gradient(to right, rgba(0,0,0,0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(0,0,0,0.03) 1px, transparent 1px)",
              backgroundSize: "48px 48px",
              WebkitMaskImage:
                "linear-gradient(to bottom, transparent, black 10%, black 90%, transparent)",
            }}
          />
          <div className="relative z-10 mx-auto flex h-full max-w-[1440px] flex-col justify-center px-6 lg:px-12">
            <div className="mb-12 max-w-[720px]">
              <span className="mb-4 block text-xs font-medium uppercase tracking-widest text-[#9ca3af]">
                What We Do
              </span>
              <h3 className="font-display text-3xl font-normal text-black lg:text-4xl">
                We turn plain-language quantum requests into verified Q# code.
              </h3>
              <p className="mt-6 text-lg font-light leading-relaxed text-[#6b7280]">
                QRAG retrieves trusted Q# documentation and examples, then generates operations that
                compile and pass tests. You get grounded output without hallucinated helpers.
              </p>
            </div>
            <div className="grid grid-cols-1 gap-12 md:grid-cols-3 lg:gap-16">
              {[
                {
                  step: "1",
                  icon: "psychology",
                  title: "Intent Capture",
                  desc:
                    "We parse the request to identify the algorithm, constraints, and expected outputs.",
                },
                {
                  step: "2",
                  icon: "library_books",
                  title: "Retrieval",
                  desc:
                    "The engine pulls the most relevant Q# docs and vetted samples for grounding.",
                },
                {
                  step: "3",
                  icon: "terminal",
                  title: "Verified Generation",
                  desc:
                    "Generated code is aligned to QDK 0.28 and benchmarked for compile + test success.",
                },
              ].map((item) => (
                <div key={item.step} className="flex flex-col gap-8 pr-4">
                  <div className="flex w-full items-baseline justify-between border-b border-gray-100 pb-6">
                    <span className="font-display text-8xl text-black opacity-20 transition-opacity duration-300 group-hover:opacity-30">
                      {item.step}
                    </span>
                    <span className="material-symbols-outlined text-[32px] font-light text-gray-400" aria-hidden="true">
                      {item.icon}
                    </span>
                  </div>
                  <div>
                    <h4 className="mb-4 text-xs font-semibold uppercase tracking-widest text-black">
                      {item.title}
                    </h4>
                    <p className="text-base font-light leading-relaxed text-[#6b7280]">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section
          className="scroll-reveal stack-section flex min-h-[calc(100vh-120px)] w-full items-center justify-center bg-[#f9fafb] py-16"
          style={{ transitionDelay: "180ms", zIndex: 2 }}
        >
          <div className="mx-auto w-full max-w-[1440px] px-6 py-8 lg:px-12">
            <div className="mx-auto max-w-[600px] border-l-2 border-[#c9a66b] pl-8">
              <span className="mb-6 block text-xs font-medium uppercase tracking-widest text-[#9ca3af]">
                Why This Matters
              </span>
              <h2 className="font-display text-4xl font-normal leading-[1.1] text-black lg:text-5xl">
                Quantum software development suffers from a scarcity of training data.
              </h2>
              <p className="mt-8 text-lg font-light leading-relaxed text-[#6b7280]">
                Standard LLMs hallucinate quantum syntax because the training corpus is orders of
                magnitude smaller than classical languages. QRAG mitigates this by dynamically
                retrieving relevant Microsoft Q# documentation and verified code samples to ground
                every generation in reality.
              </p>
            </div>
          </div>
        </section>
      </main>
    </div>
  );
}
